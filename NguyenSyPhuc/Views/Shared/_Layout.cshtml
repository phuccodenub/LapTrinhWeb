<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NguyenSyPhuc</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NguyenSyPhuc.styles.css" asp-append-version="true" />
    <style>
        :root {
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
            --secondary-color: #f59e0b;
            --dark-color: #111827;
            --light-color: #f9fafb;
            --body-bg: #f3f4f6;
            --success-color: #10b981;
        }
        
        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--body-bg);
            padding-top: 76px;
        }
        
        .navbar {
            background: linear-gradient(135deg, var(--primary-color), var(--primary-hover));
            padding: 0.8rem 1rem;
            transition: all 0.3s ease;
        }
        
        .navbar-brand {
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        
        .nav-link {
            font-weight: 500;
            padding: 0.5rem 1rem;
            transition: all 0.3s;
            border-radius: 6px;
            margin: 0 0.2rem;
        }
        
        .nav-link:hover:not(.btn) {
            background-color: rgba(255, 255, 255, 0.1);
            transform: translateY(-2px);
        }
        
        .nav-link.active:not(.btn) {
            background-color: rgba(255, 255, 255, 0.2);
        }
        
        .btn-add-product {
            background-color: var(--success-color);
            border-color: var(--success-color);
            box-shadow: 0 4px 6px rgba(16, 185, 129, 0.25);
        }
        
        .btn-add-product:hover {
            background-color: #0da271;
            border-color: #0da271;
            transform: translateY(-2px);
            box-shadow: 0 6px 8px rgba(16, 185, 129, 0.3);
        }
        
        main {
            min-height: calc(100vh - 350px);
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
            padding: 2rem;
            margin-top: 2rem;
            margin-bottom: 2rem;
        }
        
        footer {
            background: linear-gradient(135deg, var(--dark-color), #1f2937);
            border-top: 1px solid #374151;
        }
        
        footer a.text-white:hover {
            color: var(--secondary-color) !important;
        }
        
        .text-warning {
            color: var(--secondary-color) !important;
        }
        
        .social-icon {
            transition: all 0.3s;
            display: inline-flex;
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background-color: rgba(255, 255, 255, 0.1);
            justify-content: center;
            align-items: center;
        }
        
        .social-icon:hover {
            background-color: var(--secondary-color);
            transform: translateY(-3px);
        }
        
        #btn-back-to-top {
            position: fixed;
            bottom: 20px;
            right: 20px;
            display: none;
            border-radius: 50%;
            width: 45px;
            height: 45px;
            background-color: var(--primary-color);
            border-color: var(--primary-color);
            box-shadow: 0 4px 10px rgba(99, 102, 241, 0.3);
            transition: all 0.3s;
        }
        
        #btn-back-to-top:hover {
            background-color: var(--primary-hover);
            transform: translateY(-3px);
            box-shadow: 0 6px 15px rgba(99, 102, 241, 0.4);
        }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top shadow">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-box-seam me-2"></i>NguyenSyPhuc
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Home" && ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")" 
                           asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-fill me-1"></i>Trang Chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Product" && ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")" 
                           asp-area="" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-grid-fill me-1"></i>Sản Phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Privacy" ? "active" : "")" 
                           asp-area="" asp-controller="Home" asp-action="Privacy">
                            <i class="bi bi-shield-lock me-1"></i>Bảo Mật
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-add-product text-white ms-2 px-3" 
                           asp-area="" asp-controller="Product" asp-action="Add">
                            <i class="bi bi-plus-circle-fill me-1"></i>Thêm Sản Phẩm
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Back to top button -->
    <button type="button" class="btn d-flex align-items-center justify-content-center" id="btn-back-to-top">
        <i class="bi bi-arrow-up"></i>
    </button>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="text-white py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="mb-3 fw-bold text-warning">NguyenSyPhuc</h5>
                    <p>Quản lý sản phẩm chuyên nghiệp với giao diện đẹp mắt</p>
                    <p class="mb-0 text-light"><small>&copy; @DateTime.Now.Year - NguyenSyPhuc - Đồ án ASP.NET Core</small></p>
                </div>
                <div class="col-md-4">
                    <h5 class="mb-3 fw-bold text-warning">Liên Kết Nhanh</h5>
                    <ul class="list-unstyled">
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Index" class="text-decoration-none text-white"><i class="bi bi-chevron-right"></i> Trang Chủ</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Product" asp-action="Index" class="text-decoration-none text-white"><i class="bi bi-chevron-right"></i> Sản Phẩm</a></li>
                        <li class="mb-2"><a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none text-white"><i class="bi bi-chevron-right"></i> Chính Sách Bảo Mật</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="mb-3 fw-bold text-warning">Liên Hệ</h5>
                    <p><i class="bi bi-geo-alt-fill me-2"></i> 123 Đường ABC, Quận XYZ, TP.HCM</p>
                    <p><i class="bi bi-telephone-fill me-2"></i> 0123 456 789</p>
                    <p><i class="bi bi-envelope-fill me-2"></i> contact@example.com</p>
                    <div class="mt-3">
                        <a href="#" class="social-icon text-white me-2"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-icon text-white me-2"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-icon text-white me-2"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="social-icon text-white"><i class="bi bi-github"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5.3 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        // Back to top button functionality
        const mybutton = document.getElementById("btn-back-to-top");
        window.onscroll = function() {
            if (document.body.scrollTop > 20 || document.documentElement.scrollTop > 20) {
                mybutton.style.display = "block";
            } else {
                mybutton.style.display = "none";
            }
        };
        mybutton.addEventListener("click", function() {
            window.scrollTo({top: 0, behavior: 'smooth'});
        });
        
        // Add smooth scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                document.querySelector(this.getAttribute('href')).scrollIntoView({
                    behavior: 'smooth'
                });
            });
        });
        
        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar.style.padding = '0.6rem 1rem';
                navbar.style.boxShadow = '0 4px 10px rgba(0, 0, 0, 0.1)';
            } else {
                navbar.style.padding = '0.8rem 1rem';
                navbar.style.boxShadow = '0 2px 5px rgba(0, 0, 0, 0.05)';
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
