@model NguyenSyPhuc.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="card shadow-lg mb-5">
    <div class="card-header bg-primary text-white py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="mb-0">
                <i class="bi bi-info-circle me-2"></i>Chi tiết sản phẩm
            </h2>
            <div>
                <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square me-1"></i>Chỉnh sửa
                </a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger ms-2">
                    <i class="bi bi-trash me-1"></i>Xóa
                </a>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row">
            <div class="col-md-5 mb-4 mb-md-0">
                <div class="main-image-container mb-3 text-center">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Url.Content(Model.ImageUrl)" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 350px; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="bg-light p-5 rounded text-center">
                            <i class="bi bi-image text-muted" style="font-size: 8rem;"></i>
                            <p class="text-muted mt-3">Không có hình ảnh</p>
                        </div>
                    }
                </div>

                @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                {
                    <h5 class="text-primary mb-3">
                        <i class="bi bi-images me-2"></i>Hình ảnh bổ sung
                    </h5>
                    <div class="row g-2">
                        @foreach (var url in Model.ImageUrls)
                        {
                            <div class="col-4">
                                <div class="image-thumbnail">
                                    <a href="@Url.Content(url)" target="_blank">
                                        <img src="@Url.Content(url)" alt="Hình ảnh bổ sung" class="img-thumbnail shadow-sm" style="width: 100%; height: 100px; object-fit: cover;" />
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="col-md-7">
                <div class="product-details">
                    <h2 class="text-primary mb-3">@Model.Name</h2>
                    
                    <div class="mb-4">
                        <div class="d-flex align-items-center mb-3">
                            <span class="badge bg-info text-dark me-2">
                                <i class="bi bi-tag-fill me-1"></i>@(Model.Category?.Name ?? "Chưa phân loại")
                            </span>
                            <span class="badge bg-secondary">
                                <i class="bi bi-hash me-1"></i>ID: @Model.Id
                            </span>
                        </div>
                        
                        <div class="price-box p-3 bg-light rounded mb-4">
                            <h4 class="text-danger mb-0">
                                <i class="bi bi-currency-exchange me-2"></i>
                                <span class="fw-bold">@Model.Price.ToString("N0") VNĐ</span>
                            </h4>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <div class="mb-4">
                                <h5 class="text-primary">
                                    <i class="bi bi-journal-text me-2"></i>Mô tả sản phẩm
                                </h5>
                                <div class="p-3 bg-light rounded">
                                    <p class="mb-0">@Model.Description</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="bi bi-exclamation-triangle me-2"></i>Sản phẩm chưa có mô tả
                            </div>
                        }

                        <div class="action-buttons mt-4 d-flex flex-wrap gap-2">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
                            </a>
                            <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning">
                                <i class="bi bi-pencil-square me-1"></i>Chỉnh sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Xóa
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="related-section bg-light p-4 rounded shadow-sm mb-5">
    <h4 class="text-primary mb-3">
        <i class="bi bi-info-circle-fill me-2"></i>Lưu ý
    </h4>
    <p class="mb-0">
        Đây là trang hiển thị chi tiết sản phẩm. Bạn có thể sửa đổi thông tin sản phẩm bằng cách nhấp vào nút "Chỉnh sửa" hoặc trở lại danh sách sản phẩm.
    </p>
</div>

@section Scripts {
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>
}