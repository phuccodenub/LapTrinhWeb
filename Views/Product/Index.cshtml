@model IEnumerable<Product>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="display-6 fw-bold mb-0" style="color: #132740;">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>Danh Sách Sản Phẩm
            </h2>
            <p class="text-muted mb-0">Quản lý tất cả sản phẩm của bạn</p>
        </div>
        <div>
            <a asp-controller="Product" asp-action="Create" class="btn px-4 py-2"
               style="background-color: #d4af37; color: #132740; font-weight: 500;">
                <i class="bi bi-plus-circle me-2"></i>Thêm Sản Phẩm Mới
            </a>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show border-0 shadow-sm" role="alert">
            <i class="bi bi-info-circle me-2"></i>@TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header py-3" style="background: linear-gradient(135deg, #132740, #1e3a5f);">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-white">
                    <i class="bi bi-box-seam me-2"></i>Sản Phẩm
                </h5>
                <div class="d-flex gap-2">
                    <div class="input-group" style="width: 250px;">
                        <input type="text" class="form-control" id="searchInput" placeholder="Tìm sản phẩm...">
                        <button class="btn btn-light" type="button">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="productsTable">
                    <thead style="background-color: rgba(19, 39, 64, 0.03);">
                        <tr>
                            <th class="py-3">Tên sản phẩm</th>
                            <th class="py-3">Giá</th>
                            <th class="py-3">Mô tả</th>
                            <th class="py-3">Ảnh sản phẩm</th>
                            <th class="py-3">Loại</th>
                            <th class="py-3 text-center">Chức năng</th>
                        </tr>
                    </thead>
                    @if (Model != null && Model.Any())
                    {
                        <tbody>
                            @foreach (Product item in Model)
                            {
                                <tr class="align-middle">
                                    <td class="fw-medium">@item.Name</td>
                                    <td class="fw-medium" style="color: #d4af37;">@String.Format("{0:N0} VNĐ", item.Price)</td>
                                    <td>
                                        <span class="text-muted">
                                            @(item.Description != null && item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)
                                        </span>
                                    </td>
                                    <td>
                                        @if (!String.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@Url.Content(item.ImageUrl)" class="rounded shadow-sm" style="width: 60px; height: 60px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="text-center rounded bg-light d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                                <i class="bi bi-image text-muted"></i>
                                            </div>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge" style="background-color: rgba(19, 39, 64, 0.1); color: #132740;">
                                            @item.Category?.Name
                                        </span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-controller="Product" asp-action="Display" asp-route-id="@item.Id"
                                               class="btn btn-sm px-3 py-1" data-bs-toggle="tooltip" title="Xem chi tiết"
                                               style="background-color: rgba(19, 39, 64, 0.1); color: #132740;">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-controller="Product" asp-action="Update" asp-route-id="@item.Id"
                                               class="btn btn-sm px-3 py-1" data-bs-toggle="tooltip" title="Chỉnh sửa"
                                               style="background-color: rgba(212, 175, 55, 0.1); color: #d4af37;">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-sm px-3 py-1" data-bs-toggle="tooltip" title="Xóa"
                                               style="background-color: rgba(220, 53, 69, 0.1); color: #dc3545;">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    }
                    else
                    {
                        <tbody>
                            <tr>
                                <td colspan="6">
                                    <div class="text-center py-5">
                                        <i class="bi bi-box2 text-muted" style="font-size: 3rem;"></i>
                                        <p class="mt-3 mb-0 text-muted">Chưa có sản phẩm nào</p>
                                        <a asp-controller="Product" asp-action="Create" class="btn mt-3"
                                           style="background-color: #d4af37; color: #132740;">
                                            <i class="bi bi-plus-circle me-2"></i>Thêm Sản Phẩm Đầu Tiên
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Enable tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        });

        // Simple search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            var input, filter, table, tr, td, i, txtValue;
            input = document.getElementById('searchInput');
            filter = input.value.toUpperCase();
            table = document.getElementById('productsTable');
            tr = table.getElementsByTagName('tr');

            for (i = 1; i < tr.length; i++) {
                // Search in name column (index 0)
                td = tr[i].getElementsByTagName('td')[0];
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) > -1) {
                        tr[i].style.display = '';
                    } else {
                        tr[i].style.display = 'none';
                    }
                }
            }
        });
    </script>
}