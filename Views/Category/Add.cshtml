@model NguyenSyPhuc.Models.Category
@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house me-1"></i>Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-controller="Category" asp-action="Index" class="text-decoration-none"><i class="bi bi-diagram-3 me-1"></i>Danh mục</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thêm danh mục mới</li>
    </ol>
</nav>

<div class="card border-0 shadow mb-5">
    <div class="card-header py-3" style="background: linear-gradient(135deg, #132740, #1e3a5f);">
        <h2 class="mb-0 text-white">
            <i class="bi bi-plus-circle me-2"></i>Thêm danh mục mới
        </h2>
    </div>
    <div class="card-body p-4">
        <form asp-action="Add" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3 p-3 border-danger border-start border-4 rounded-3"
                 style="background-color: rgba(220, 53, 69, 0.05);"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold" style="color: #132740;">Tên danh mục</label>
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-tag"></i></span>
                    <input asp-for="Name" class="form-control border-start-0" placeholder="Nhập tên danh mục" />
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="bi bi-file-text"></i></span>
                </div>
            </div>

            <div class="d-flex gap-3 mt-4">
                <a asp-action="Index" class="btn btn-light px-4 py-2 border">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
                <button type="submit" class="btn px-4 py-2"
                        style="background-color: #d4af37; color: #132740; font-weight: 500;">
                    <i class="bi bi-save me-2"></i>Lưu danh mục
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}