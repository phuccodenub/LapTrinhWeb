@model IEnumerable<NguyenSyPhuc.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house me-1"></i>Trang chủ</a></li>
        <li class="breadcrumb-item active" aria-current="page"><i class="bi bi-diagram-3 me-1"></i>Danh mục</li>
    </ol>
</nav>

<div class="card border-0 shadow mb-5">
    <div class="card-header py-3" style="background: linear-gradient(135deg, #132740, #1e3a5f);">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="mb-0 text-white">
                <i class="bi bi-diagram-3 me-2"></i>Danh sách danh mục
            </h2>
            <a asp-action="Add" class="btn btn-light">
                <i class="bi bi-plus-circle me-2"></i>Thêm danh mục mới
            </a>
        </div>
    </div>
    <div class="card-body p-4">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên danh mục</th>
                            <th>Mô tả</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in Model)
                        {
                            <tr>
                                <td>@category.Id</td>
                                <td>@category.Name</td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Update" asp-route-id="@category.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil-square"></i> Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center p-5">
                <i class="bi bi-exclamation-circle" style="font-size: 3rem;"></i>
                <p class="mt-3">Chưa có danh mục nào. Hãy thêm danh mục mới!</p>
                <a asp-action="Add" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle me-2"></i>Thêm danh mục
                </a>
            </div>
        }
    </div>
</div>