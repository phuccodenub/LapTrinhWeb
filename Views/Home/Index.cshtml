                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Promo Banner -->
<section class="mb-5">
    <div class="card border-0 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-6">
                <img src="https://images.unsplash.com/photo-1607082350899-7e105aa886ae?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80" class="w-100" style="height: 100%; object-fit: cover;" alt="Promo">
            </div>
            <div class="col-md-6" style="background: linear-gradient(135deg, #132740, #1e3a5f);">
                <div class="card-body p-5 text-white h-100 d-flex flex-column justify-content-center">
                    <h3 class="card-title fw-bold mb-4">Khuyến mãi đặc biệt</h3>
                    <h2 class="fw-bold mb-3" style="color: #d4af37;">Giảm giá lên tới 50%</h2>
                    <p class="card-text mb-4">Đừng bỏ lỡ cơ hội sở hữu những sản phẩm chất lượng với giá ưu đãi. Chỉ áp dụng trong thời gian giới hạn!</p>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-lg align-self-start"
                       style="background-color: #d4af37; color: #132740; font-weight: 500;">
                        Khám phá ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Benefits Section -->
<section class="mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold mb-3" style="color: #132740;">Tại sao chọn chúng tôi?</h2>
        <p class="text-muted mx-auto" style="max-width: 600px;">Chúng tôi cam kết mang đến cho bạn những sản phẩm chất lượng cao với dịch vụ tốt nhất</p>
    </div>
    <div class="row g-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="mb-3 mx-auto" style="width: 70px; height: 70px; background-color: rgba(19, 39, 64, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-truck" style="font-size: 2rem; color: #132740;"></i>
                </div>
                <h5 class="fw-bold" style="color: #132740;">Giao hàng miễn phí</h5>
                <p class="text-muted mb-0">Miễn phí giao hàng cho các đơn hàng từ 500.000 VNĐ</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="mb-3 mx-auto" style="width: 70px; height: 70px; background-color: rgba(19, 39, 64, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-shield-check" style="font-size: 2rem; color: #132740;"></i>
                </div>
                <h5 class="fw-bold" style="color: #132740;">Bảo hành 12 tháng</h5>
                <p class="text-muted mb-0">Tất cả sản phẩm đều được bảo hành chính hãng</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="mb-3 mx-auto" style="width: 70px; height: 70px; background-color: rgba(19, 39, 64, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-arrow-repeat" style="font-size: 2rem; color: #132740;"></i>
                </div>
                <h5 class="fw-bold" style="color: #132740;">Đổi trả 30 ngày</h5>
                <p class="text-muted mb-0">Dễ dàng đổi trả trong vòng 30 ngày nếu không hài lòng</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <div class="mb-3 mx-auto" style="width: 70px; height: 70px; background-color: rgba(19, 39, 64, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-headset" style="font-size: 2rem; color: #132740;"></i>
                </div>
                <h5 class="fw-bold" style="color: #132740;">Hỗ trợ 24/7</h5>
                <p class="text-muted mb-0">Đội ngũ hỗ trợ luôn sẵn sàng giúp đỡ bạn</p>
            </div>
        </div>
    </div>
</section>

<!-- Newsletter Section -->
<section class="mb-5">
    <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, rgba(19, 39, 64, 0.03), rgba(19, 39, 64, 0.08));">
        <div class="card-body p-5 text-center">
            <h3 class="fw-bold mb-3" style="color: #132740;">Đăng ký nhận tin</h3>
            <p class="text-muted mb-4 mx-auto" style="max-width: 600px;">
                Đăng ký nhận thông tin về sản phẩm mới và các chương trình khuyến mãi hấp dẫn từ chúng tôi.
            </p>
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="email" class="form-control p-3" placeholder="Nhập email của bạn">
                        <button class="btn px-4" type="button" style="background-color: #d4af37; color: #fff; font-weight: 500;">
                            Đăng ký ngay
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .product-card {
        transition: all 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }

    .carousel-item img {
        filter: brightness(0.85);
    }

    .carousel-caption {
        backdrop-filter: blur(2px);
    }
</style>


@section Scripts {
    <script>
        // Initialize carousel
        var myCarousel = document.querySelector('#mainCarousel')
        var carousel = new bootstrap.Carousel(myCarousel, {
            interval: 5000,
            wrap: true
        })
    </script>
}